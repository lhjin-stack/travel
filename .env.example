# Google OAuth 2.0 credentials
# Google Cloud Console > APIs & Services > Credentials 에서 발급
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# 콜백 URL (로컬: http://localhost:3000/auth/google/callback)
# 배포 후: https://your-domain.com/auth/google/callback
CALLBACK_URL=http://localhost:3000/auth/google/callback

# 세션 암호화 키 (임의의 긴 문자열로 변경)
SESSION_SECRET=change-this-to-a-long-random-string

# 포트 (기본 3000)
PORT=3000

# 배포 환경에서는 production으로 설정 (HTTPS 쿠키 활성화)
NODE_ENV=development
